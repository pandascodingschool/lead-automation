<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CRM — Sign In</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f0f4f8;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,.10);
      padding: 40px 36px;
      width: 100%;
      max-width: 400px;
    }
    .logo {
      text-align: center;
      margin-bottom: 28px;
    }
    .logo h1 { font-size: 22px; color: #1a202c; font-weight: 700; }
    .logo p  { font-size: 13px; color: #718096; margin-top: 4px; }
    .error-box {
      background: #fff5f5;
      border: 1px solid #feb2b2;
      color: #c53030;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      margin-bottom: 18px;
    }
    label { display: block; font-size: 13px; font-weight: 600; color: #4a5568; margin-bottom: 6px; }
    input[type="email"], input[type="password"] {
      width: 100%; padding: 10px 12px;
      border: 1px solid #cbd5e0; border-radius: 8px;
      font-size: 14px; outline: none;
      transition: border-color .15s;
    }
    input:focus { border-color: #4299e1; box-shadow: 0 0 0 3px rgba(66,153,225,.2); }
    .field { margin-bottom: 18px; }
    .btn {
      width: 100%; padding: 11px;
      background: #3182ce; color: #fff;
      border: none; border-radius: 8px;
      font-size: 15px; font-weight: 600;
      cursor: pointer; margin-top: 4px;
      transition: background .15s;
    }
    .btn:hover { background: #2b6cb0; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <h1>IndiaMART CRM</h1>
      <p>Sign in to continue</p>
    </div>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required autofocus />
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn">Sign In</button>
    </form>
  </div>
</body>
</html>
