{
  "name": "indiamart-lead-automation",
  "version": "1.0.0",
  "description": "IndiaMART Lead Automation POC - Auto receive, store and assign leads",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "dotenv": "^16.4.5",
    "ejs": "^5.0.2",
    "express": "^4.19.2",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.13.0"
  }
}
