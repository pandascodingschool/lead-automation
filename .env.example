# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/indiamart_leads"

# Server port
PORT=3000

# ----------------------------
# Twilio WhatsApp (Sandbox)
# ----------------------------
# Get these from: https://console.twilio.com → Messaging → Try it out → Send a WhatsApp message
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio sandbox number (keep the whatsapp: prefix)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Set to "true" to enable WhatsApp notifications; "false" to skip (useful during dev)
WHATSAPP_ENABLED=true
